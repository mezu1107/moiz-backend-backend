# ===================================
# APP & SERVER
# ===================================
NODE_ENV=production
PORT=5000

# Your app URLs (comma separated for multiple)
CLIENT_URL=http://localhost:3000,http://localhost:3001,https://yourapp.pk,https://admin.yourapp.pk

# ===================================
# DATABASE
# ===================================
MONGO_URI=mongodb://127.0.0.1:27017/amfood
# OR for MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/amfood?retryWrites=true&w=majority

# ===================================
# JWT AUTH
# ===================================
JWT_SECRET=your-super-secret-jwt-key-here-at-least-64-chars-1234567890abcdef
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# ===================================
# CLOUDINARY (Menu Images, CNIC, Profile Pics)
# ===================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_api_secret_here_very_long
CLOUDINARY_FOLDER=amfood

# ===================================
# EMAIL (Nodemailer - Gmail Recommended)
# ===================================
EMAIL_USER=yourapp.pk@gmail.com
EMAIL_PASS=your_app_password_16_digits   # ← Use App Password (not real password)

# ===================================
# STRIPE PAYMENT
# ===================================
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===================================
# FCM (Push Notifications for Riders & Users)
# ===================================
FCM_SERVER_KEY=your_fcm_server_key_from_firebase_console
FCM_PROJECT_ID=amfood-app-123
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASC...\n-----END PRIVATE KEY-----\n"
FCM_CLIENT_EMAIL=firebase-adminsdk-xyz@amfood-app-123.iam.gserviceaccount.com
# ===================================
# GOOGLE MAPS / LOCATION
# ===================================
GOOGLE_MAPS_API_KEY=AIzaSyBxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===================================
# APP INFO
# ===================================
APP_NAME=AM Food
APP_CONTACT=+923001234567
SUPPORT_EMAIL=support@yourapp.pk

# ===================================
# RATE LIMIT & SECURITY
# ===================================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=500

# ===================================
# LOGGING (Optional - for Winston)
# ===================================
LOG_LEVEL=info

# ===================================
# BACKUP SETTINGS (Optional)
# ===================================
BACKUP_ENABLED=false
BACKUP_PATH=./backups


# Primary Gmail
EMAIL_USER_1=no-reply@foodapp.pk
EMAIL_PASS_1=abcd efgh ijkl mnop   # 16-digit App Password

