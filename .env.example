# ===================================
# AM Food Backend - Environment Variables
# Copy this file to .env and fill with your actual values
# ===================================

# ---- Server Configuration ----
PORT=5000
NODE_ENV=development           # Use "production" in production

# ---- Database (MongoDB) ----
# Local MongoDB URI
MONGODB_URI=mongodb://127.0.0.1:27017/amfood
# For MongoDB Atlas, use:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/amfood?retryWrites=true&w=majority

# ---- Authentication ----
JWT_SECRET=your_very_long_random_jwt_secret_here_change_it

# ---- Frontend URL (for CORS & Socket.IO) ----
CLIENT_URL=http://localhost:3000
# Example for production with multiple URLs:
# CLIENT_URL=https://amfood.pk,https://www.amfood.pk

# ---- Stripe API Keys ----
STRIPE_SECRET=sk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=XXXXXXXXXXXXXXXXXXXXXX
# ---- Cloudinary Configuration (optional) ----
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OR alternatively, use the full URL:
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# ---- Base URL (optional, for building links) ----
BASE_URL=http://localhost:5000

# ---- Geo & Delivery Settings ----
DEFAULT_CURRENCY=PKR
DELIVERY_RADIUS_KM=10

# ---- Admin User (first admin setup) ----
ADMIN_PHONE=+923001234567
ADMIN_NAME=Admin Name
ADMIN_EMAIL=admin@example.com